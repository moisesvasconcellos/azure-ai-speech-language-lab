from azure.core.credentials import AzureKeyCredential
from azure.ai.textanalytics import TextAnalyticsClient

# Substitua pelos dados do seu recurso no Azure
endpoint = "https://SEU-RECURSO.cognitiveservices.azure.com/"
key = "SUA_CHAVE"

# Cria o cliente
client = TextAnalyticsClient(
    endpoint=endpoint,
    credential=AzureKeyCredential(key)
)

# Texto para análise
documents = [
    "This hotel is old, but the staff was helpful and the room was comfortable."
]

# Chama o serviço
response = client.analyze_sentiment(documents=documents)[0]

# Exibe o resultado
print("Sentimento geral:", response.sentiment)
print("Confiança:")
print("  Positivo:", response.confidence_scores.positive)
print("  Neutro:", response.confidence_scores.neutral)
print("  Negativo:", response.confidence_scores.negative)
